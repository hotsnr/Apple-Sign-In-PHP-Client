{
    "name": "hotsnr/apple-sign-in-php-client",
    "description": "PHP Client for Apple Sign-In",
    "keywords": [
        "Apple",
        "Apple Sign-in",
        "Apple Jwt"
    ],
    "require": {
        "php": ">=5.6",
        "guzzlehttp/guzzle": "^7.9",
        "firebase/php-jwt": "^6.10",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "CurrencyFair\\AppleId\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "test"
        }
    },
    "license": "Apache-2.0"
}
